---
interface Props {
	tags: string[];
}

const { tags } = Astro.props;
---

<ul class="tags">
	{tags.map((t) => <li class="tag">{t}</li>)}
</ul>

<style>
	.tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		margin-left: 0;
		list-style: none;
	}

	.tag {
		display: inline-flex;
		align-items: center;
		flex-shrink: 0;
		gap: 0.4rem;
		background-color: var(--color-secondary-light);
		color: var(--color-secondary);
		padding: 0.3rem 0.7rem;
		border-radius: 999px;
		border: 1px solid var(--color-border);
		font-family: var(--font-mono);
		font-size: 0.75rem;
		white-space: nowrap;
	}

	.tag::before {
		content: '';
		width: 6px;
		height: 6px;
		flex-shrink: 0;
		border-radius: 50%;
		background-color: currentColor;
	}
</style>
